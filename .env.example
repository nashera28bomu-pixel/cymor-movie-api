# Moviebox API Configuration
MOVIEBOX_API_V1_HOST=h5.aoneroom.com
MOVIEBOX_API_V2_HOST=h5-api.aoneroom.com
MOVIEBOX_API_V3_HOST=h5-api.aoneroom.com

# Redis Configuration (Optional - for caching)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# API Configuration
API_TITLE=Cymor Movie API
API_VERSION=1.0.0
API_DESCRIPTION=Modern streaming and movie download API powered by Moviebox
API_DEBUG=false

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
CORS_CREDENTIALS=true
CORS_METHODS=["GET", "POST", "OPTIONS"]
CORS_HEADERS=["*"]

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Download Configuration
DOWNLOAD_TIMEOUT=3600
DOWNLOAD_MAX_CONCURRENT=3
DOWNLOAD_TEMP_DIR=/tmp/cymor_downloads

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Server
HOST=0.0.0.0
PORT=8000
